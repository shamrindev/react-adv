#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Keep the pre-commit hook fast so it doesn't get bypassed with --no-verify:
# format staged files and lint. The production build, Storybook build and the
# full test suite run in CI, not on every commit.
npx pretty-quick --staged
npm run lint:ts
npm run lint:scss
