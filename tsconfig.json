{
  "compilerOptions": {
    "outDir": "./dist/",
    // flag every implicit `any`; explicit `any` is still allowed where intended
    "noImplicitAny": true,
    "module": "ESNext",
    // compile target — broad browser support
    "target": "es5",
    "jsx": "react-jsx",
    // process JS files alongside TS
    "allowJs": true,
    "strict": true,
    "moduleResolution": "node",
    // absolute imports
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    // interop with CommonJS packages when importing them as ES modules
    "esModuleInterop": true,
    // allow `import React from 'react'` for libs without a default export
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "isolatedModules": true
  },
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS"
    }
  },
  "include": ["./config/jest/setupTests.ts", "./src/**/*.ts", "./src/**/*.tsx"]
}
